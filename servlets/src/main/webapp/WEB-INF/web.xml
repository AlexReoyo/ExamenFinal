<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <servlet>
    <servlet-name>listAllProductosServlet</servlet-name>
    <servlet-class>com.politecnicomalaga.tienda.view.listAllProductosServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>listAllProductosServlet</servlet-name>
    <url-pattern>/listarproductos</url-pattern>
  </servlet-mapping>
    <servlet>
        <servlet-name>findProductoXCodigo</servlet-name>
        <servlet-class>com.politecnicomalaga.tienda.view.findProductoXCodigo</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>findProductoXCodigo</servlet-name>
        <url-pattern>/findproduct</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>findClienteXDni</servlet-name>
        <servlet-class>com.politecnicomalaga.tienda.view.findClienteXDni</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>findClienteXDni</servlet-name>
        <url-pattern>/findcliente</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>listAllClientsServlet</servlet-name>
        <servlet-class>com.politecnicomalaga.tienda.view.listAllClientsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>listAllClientsServlet</servlet-name>
        <url-pattern>/listarClientes</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>listProdctosXPedido</servlet-name>
        <servlet-class>com.politecnicomalaga.tienda.view.listProductosXPedido</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>listProdctosXPedido</servlet-name>
        <url-pattern>/listarproductospedido</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>importData</servlet-name>
        <servlet-class>com.politecnicomalaga.tienda.view.importData</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>importData</servlet-name>
        <url-pattern>/importar</url-pattern>
    </servlet-mapping>

</web-app>